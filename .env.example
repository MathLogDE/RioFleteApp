# Copiá este archivo a ".env" y completá con los valores de tu proyecto Supabase.
# Settings -> API en el panel de Supabase.
#
# IMPORTANTE: acá va SOLO la "anon" / publishable key (es pública por diseño y
# está protegida por las políticas RLS). NUNCA pongas la "service_role" key en
# el frontend: tiene permisos totales y saltea RLS.

VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=TU_ANON_KEY
